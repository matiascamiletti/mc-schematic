{
  "$schema": "../node_modules/@angular-devkit/schematics/collection-schema.json",
  "schematics": {
    "mc-schematic": {
      "description": "A blank schematic.",
      "factory": "./mc-schematic/index#mcSchematic"
    },
    "init": {
      "description": "Config a new project.",
      "factory": "./init/index#init"
    },
    "add-login-page": {
      "description": "Config and create login page",
      "factory": "./add-login-page/index#addLoginPage"
    },
    "install-layout-fuse": {
      "description": "Install layout fuse",
      "factory": "./install-layout-fuse/index#install"
    },
    "addTable": {
      "description": "Add Table",
      "factory": "./add-table/index#addTable",
      "schema": "./add-table/schema.json"
    },
    "create-crud": {
      "description": "Create Crud",
      "factory": "./create-crud/index#createCrud",
      "schema": "./create-crud/schema.json"
    },
    "set-tenant-backend": {
      "description": "Set multi tenant backend",
      "factory": "./set-tenant-backend/index#install"
    }
  }
}